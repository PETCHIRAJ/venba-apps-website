---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import AppCard from '../components/AppCard.astro';
import Footer from '../components/Footer.astro';
import appsData from '../data/apps.json';
import { Mail, Smartphone, FileText } from 'lucide-astro';
---

<Layout>
    <Header />

    <section class="apps">
        <div class="app-grid">
            {appsData.apps.map((app) => (
                <AppCard
                    icon={app.icon}
                    name={app.name}
                    category={app.category}
                    description={app.description}
                    features={app.features}
                    storeLink={app.storeLink}
                    status={app.status as 'available' | 'coming-soon'}
                    accentColor={app.accentColor}
                />
            ))}
        </div>
    </section>

    <section class="about-contact">
        <div class="about-content">
            <p>Solo developer building free finance tools for India — simple design, local language support, and user privacy first.</p>
        </div>

        <div class="contact-links">
            <a href="mailto:contact.venbaapps@gmail.com" class="contact-link">
                <Mail class="contact-icon" size={20} />
                <span>contact.venbaapps@gmail.com</span>
            </a>
            <a href="https://play.google.com/store/apps/dev?id=8464608221563186460" target="_blank" class="contact-link">
                <Smartphone class="contact-icon" size={20} />
                <span>Google Play Store</span>
            </a>
            <a href="https://blog.venba.dev" target="_blank" class="contact-link">
                <FileText class="contact-icon" size={20} />
                <span>Tech & Finance Blog</span>
            </a>
        </div>
    </section>

    <Footer />
</Layout>
