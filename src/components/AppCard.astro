---
import { Lock, Zap, Smartphone, Cloud, Calculator, Receipt, TrendingUp, PiggyBank, Globe, BadgeCheck, BookOpen, Gem, Scale } from 'lucide-astro';

export interface Props {
  icon: string;
  name: string;
  category: string;
  features?: string[];
  description?: string;
  storeLink?: string | null;
  status: 'available' | 'coming-soon';
  isPlaceholder?: boolean;
  accentColor?: string;
}

const { icon, name, category, features, description, storeLink, status, isPlaceholder = false, accentColor = '#3498db' } = Astro.props;

// Map feature text to icons
const getFeatureIcon = (feature: string) => {
  // Privacy Expense Tracker icons
  if (feature.includes('Encrypted') || feature.includes('storage')) return Lock;
  if (feature.includes('3-tap') || feature.includes('quick')) return Zap;
  if (feature.includes('offline')) return Smartphone;
  if (feature.includes('Drive') || feature.includes('backup')) return Cloud;

  // Home Loan Calculator icons
  if (feature.includes('EMI') || feature.includes('prepayment') || feature.includes('calculator')) return Calculator;
  if (feature.includes('Tax') || feature.includes('benefits')) return Receipt;
  if (feature.includes('Compare') || feature.includes('bank')) return TrendingUp;
  if (feature.includes('Save') || feature.includes('lakhs') || feature.includes('strategies')) return PiggyBank;

  // Gold Rate Today icons
  if (feature.includes('22K') || feature.includes('24K') || feature.includes('gold')) return Gem;
  if (feature.includes('trend') || feature.includes('returns')) return TrendingUp;
  if (feature.includes('cost breakdown') || feature.includes('GST') || feature.includes('making')) return Receipt;
  if (feature.includes('guides') || feature.includes('city')) return BookOpen;

  // YojanaCalc icons
  if (feature.includes('schemes') || feature.includes('EPF')) return Calculator;
  if (feature.includes('Bilingual') || feature.includes('EN/HI') || feature.includes('Tamil') || feature.includes('English')) return Globe;
  if (feature.includes('free & accurate') || feature.includes('accurate')) return BadgeCheck;
  if (feature.includes('SEO') || feature.includes('Hindi searches')) return TrendingUp;

  // TN Pension icons
  if (feature.includes('pension') || feature.includes('CPS') || feature.includes('TAPS') || feature.includes('comparison')) return Scale;
  if (feature.includes('Gratuity') || feature.includes('corpus') || feature.includes('projection')) return PiggyBank;
  if (feature.includes('free & offline') || feature.includes('100% free')) return BadgeCheck;

  return null;
};

// Determine button text based on link type
const isWebApp = storeLink && !storeLink.includes('play.google.com');
const ctaLabel = isWebApp ? 'Visit →' : 'Install →';
---

<div class="app-card" style={`--accent: ${accentColor}`}>
    {isPlaceholder ? (
        <div class="placeholder-icon">🚀</div>
    ) : (
        <img src={icon} alt={name} class="app-icon">
    )}

    <div class="app-card-body">
        <div class="app-card-top">
            <div>
                <h3>{name}</h3>
                {!isPlaceholder && <p class="category" style={`color: ${accentColor}`}>{category}</p>}
            </div>
            {storeLink ? (
                <a href={storeLink} target="_blank" rel="noopener noreferrer" class="app-store-link">
                    <span class={`status ${status}`}>
                        {status === 'available' ? ctaLabel : 'Coming Soon'}
                    </span>
                </a>
            ) : (
                <span class={`status ${status}`}>Coming Soon</span>
            )}
        </div>

        {description && <p class="app-description">{description}</p>}

        {features && features.length > 0 && (
            <div class="features-list">
                {features.map((feature) => {
                    const IconComponent = getFeatureIcon(feature);
                    return (
                        <div class="feature-item">
                            {IconComponent && <IconComponent size={14} class="feature-icon" />}
                            <span>{feature}</span>
                        </div>
                    );
                })}
            </div>
        )}
    </div>
</div>